  },
  "bugs": {
    "url": "https://github.com/haydywoo/DAVE/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
