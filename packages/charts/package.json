  "description": "DAVE chart components — built on Recharts with DAVE design tokens.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:fix": "prettier --write ."
  },
  "keywords": [
    "react",
    "charts",
    "recharts",
    "data-visualization",
    "design-system"
  ],
  "author": "Haydyn Phillips",
