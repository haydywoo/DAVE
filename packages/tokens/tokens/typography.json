{
  "font": {
    "family": {
      "display": {
        "$value": "'Bricolage Grotesque', sans-serif",
        "$type": "fontFamily",
        "$description": "Display and heading typeface — geometric grotesque, distinctive at large sizes"
      },
      "body": {
        "$value": "'Cabinet Grotesk', sans-serif",
        "$type": "fontFamily",
        "$description": "UI and body typeface — warm geometric grotesque, clean and purposeful"
      },
      "mono": {
        "$value": "'JetBrains Mono', monospace",
        "$type": "fontFamily",
        "$description": "Code typeface"
      }
    },
    "size": {
      "xs":   { "$value": "0.75rem",  "$type": "dimension" },
      "sm":   { "$value": "0.875rem", "$type": "dimension" },
      "md":   { "$value": "1rem",     "$type": "dimension" },
      "lg":   { "$value": "1.125rem", "$type": "dimension" },
      "xl":   { "$value": "1.25rem",  "$type": "dimension" },
      "2xl":  { "$value": "1.5rem",   "$type": "dimension" },
      "3xl":  { "$value": "1.875rem", "$type": "dimension" },
      "4xl":  { "$value": "2.25rem",  "$type": "dimension" },
      "5xl":  { "$value": "3rem",     "$type": "dimension" },
      "6xl":  { "$value": "3.75rem",  "$type": "dimension" },
      "7xl":  { "$value": "4.5rem",   "$type": "dimension" }
    },
    "weight": {
      "regular":   { "$value": "400", "$type": "fontWeight" },
      "medium":    { "$value": "500", "$type": "fontWeight" },
      "semibold":  { "$value": "600", "$type": "fontWeight" },
      "bold":      { "$value": "700", "$type": "fontWeight" },
      "extrabold": { "$value": "800", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":  { "$value": "1.1",  "$type": "number" },
      "snug":   { "$value": "1.3",  "$type": "number" },
      "normal": { "$value": "1.5",  "$type": "number" },
      "relaxed":{ "$value": "1.65", "$type": "number" }
    },
    "letterSpacing": {
      "tight":  { "$value": "-0.02em", "$type": "dimension" },
      "normal": { "$value": "0em",     "$type": "dimension" },
      "wide":   { "$value": "0.04em",  "$type": "dimension" },
      "wider":  { "$value": "0.08em",  "$type": "dimension" }
    }
  }
}
